@page "/account/login"

@layout SmartCampus.Components.Layout.AuthLayout
@rendermode @(new InteractiveServerRenderMode())
@inject NavigationManager Navigation

<PageTitle>Login — SmartCampus</PageTitle>

<div class="au-login-shell">
    <div class="au-login-panel animate-in">
        <aside class="au-login-visual">
            <div class="au-login-overlay"></div>
            <div class="au-login-brand-block">
                <div class="au-logo-mark"><i class="bi bi-mortarboard-fill"></i></div>
                <div>
                    <h1>Smart<span>Campus</span></h1>
                    <p>Air University Islamabad Campus</p>
                </div>
            </div>

            <div class="au-visual-content">
                <span class="portal-chip"><span></span> Unified Academic Portal</span>
                <h2>One workspace for students, faculty, HOD and academic office.</h2>
                <p>Course registration, attendance, GCR-style classrooms, announcements, assignments, records and student services are connected through a role-based workflow.</p>

                <div class="portal-feature-grid">
                    <div><i class="bi bi-shield-check"></i><span>Role secure</span></div>
                    <div><i class="bi bi-broadcast-pin"></i><span>Live updates</span></div>
                    <div><i class="bi bi-easel2"></i><span>GCR rooms</span></div>
                    <div><i class="bi bi-clipboard2-check"></i><span>Attendance</span></div>
                </div>
            </div>
        </aside>

        <main class="au-login-card">
            <div class="mobile-brand">
                <div class="au-logo-mark compact"><i class="bi bi-mortarboard-fill"></i></div>
                <div>
                    <h1>Smart<span>Campus</span></h1>
                    <p>Air University Islamabad Campus</p>
                </div>
            </div>

            @if (step == 1)
            {
                <div class="auth-heading">
                    <span class="auth-kicker">Portal Access</span>
                    <h2>Select your workspace</h2>
                    <p>Each role opens only the actions assigned to that university office.</p>
                </div>

                <div class="role-grid-premium">
                    <button class="portal-role-card registrar" @onclick='() => PickRole("Admin")'>
                        <span class="role-orb"><i class="bi bi-shield-lock-fill"></i></span>
                        <strong>Registrar</strong>
                        <small>Academic records and requests</small>
                    </button>
                    <button class="portal-role-card hod" @onclick='() => PickRole("HOD")'>
                        <span class="role-orb"><i class="bi bi-building-fill"></i></span>
                        <strong>HOD</strong>
                        <small>Offerings, faculty and department</small>
                    </button>
                    <button class="portal-role-card faculty" @onclick='() => PickRole("Faculty")'>
                        <span class="role-orb"><i class="bi bi-person-video3"></i></span>
                        <strong>Faculty</strong>
                        <small>Courses, attendance and grading</small>
                    </button>
                    <button class="portal-role-card student" @onclick='() => PickRole("Student")'>
                        <span class="role-orb"><i class="bi bi-mortarboard-fill"></i></span>
                        <strong>Student</strong>
                        <small>Learning, services and requests</small>
                    </button>
                </div>

                <details class="demo-access-box">
                    <summary><i class="bi bi-key"></i> Project access accounts</summary>
                    <div class="demo-account-list">
                        <div><span>Registrar</span><strong>admin@au.edu.pk</strong><em>admin123</em></div>
                        <div><span>HOD</span><strong>hod.cs@au.edu.pk</strong><em>hod12345</em></div>
                        <div><span>Faculty</span><strong>bilal.raza@au.edu.pk</strong><em>faculty123</em></div>
                        <div><span>Student</span><strong>241844@students.au.edu.pk</strong><em>bilal123</em></div>
                    </div>
                </details>
            }
            else if (step == 2)
            {
                <button class="login-back-btn" @onclick="GoBack"><i class="bi bi-arrow-left"></i> Back</button>

                <div class="auth-heading">
                    <span class="auth-kicker faculty-text">Faculty Workspace</span>
                    <h2>Choose session mode</h2>
                    <p>Teacher mode focuses on classroom operations. Advisor mode focuses on student guidance.</p>
                </div>

                <div class="role-grid-premium two">
                    <button class="portal-role-card faculty @(facultyMode == "Teacher" ? "selected" : "")" @onclick='() => PickFacultyMode("Teacher")'>
                        <span class="role-orb"><i class="bi bi-person-video3"></i></span>
                        <strong>Teacher</strong>
                        <small>Courses, assignments and attendance</small>
                    </button>
                    <button class="portal-role-card student @(facultyMode == "Advisor" ? "selected" : "")" @onclick='() => PickFacultyMode("Advisor")'>
                        <span class="role-orb"><i class="bi bi-person-lines-fill"></i></span>
                        <strong>Advisor</strong>
                        <small>Advisees and academic support</small>
                    </button>
                </div>
            }
            else if (step == 3)
            {
                <button class="login-back-btn" @onclick="GoBack"><i class="bi bi-arrow-left"></i> @(selectedRole == "Faculty" ? "Mode selection" : "Roles")</button>

                <div class="selected-role-strip" style="--role-color:@RoleColor; --role-bg:@RoleBg">
                    <span><i class="bi @RoleIcon"></i></span>
                    <div>
                        <strong>@RoleLabel</strong>
                        <small>@RoleSub</small>
                    </div>
                    <em>@selectedRole@(selectedRole == "Faculty" ? $" · {facultyMode}" : "")</em>
                </div>

                @if (showError)
                {
                    <div class="alert sc-alert-error d-flex align-items-center gap-2 mb-3 py-2">
                        <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                        <span style="font-size:.88rem">Invalid email or password. Please verify the selected role.</span>
                    </div>
                }

                <form method="post" action="/auth/signin" data-enhance="false" class="premium-login-form">
                    <input type="hidden" name="selectedrole" value="@selectedRole" />
                    <input type="hidden" name="facultymode" value="@facultyMode" />

                    <div class="form-group-premium">
                        <label>@(selectedRole == "Student" ? "Student Email" : "University Email")</label>
                        <div class="sc-input-group premium">
                            <span class="sc-input-icon"><i class="bi bi-envelope"></i></span>
                            <input name="email" type="email" class="form-control sc-input" placeholder="@EmailHint" autocomplete="email" required />
                        </div>
                    </div>

                    <div class="form-group-premium">
                        <label>Password</label>
                        <div class="sc-input-group premium">
                            <span class="sc-input-icon"><i class="bi bi-lock"></i></span>
                            <input name="password" type="@(showPw ? "text" : "password")" class="form-control sc-input sc-input-pw" placeholder="••••••••" autocomplete="current-password" required />
                            <button type="button" class="sc-pw-toggle" @onclick="() => showPw = !showPw" tabindex="-1">
                                <i class="bi @(showPw ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <div class="login-options-row">
                        <label class="remember-box">
                            <input name="remember" type="checkbox" value="true" />
                            <span>Remember this device</span>
                        </label>
                        <span class="secure-text"><i class="bi bi-lock-fill"></i> Secure session</span>
                    </div>

                    <button type="submit" class="btn premium-login-btn w-100" style="--role-color:@RoleColor">
                        Login to @RoleLabel
                        <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </form>
            }
        </main>
    </div>
</div>

@code {
    private int step = 1;
    private string selectedRole = "";
    private string facultyMode = "Teacher";
    private bool showError;
    private bool showPw;

    protected override void OnInitialized()
    {
        var q = System.Web.HttpUtility.ParseQueryString(new Uri(Navigation.Uri).Query);
        showError = q["error"] == "invalid";

        if (showError)
        {
            selectedRole = q["role"] ?? "";
            facultyMode = q["fmode"] ?? "Teacher";
            step = string.IsNullOrEmpty(selectedRole) ? 1 : 3;
        }
    }

    private void PickRole(string role)
    {
        selectedRole = role;
        showError = false;
        step = role == "Faculty" ? 2 : 3;
    }

    private void PickFacultyMode(string mode)
    {
        facultyMode = mode;
        showError = false;
        step = 3;
    }

    private void GoBack()
    {
        showError = false;
        step--;
        if (step < 1) step = 1;
        if (step == 2 && selectedRole != "Faculty") step = 1;
    }

    private string RoleIcon => selectedRole switch
    {
        "Admin" => "bi-shield-lock-fill",
        "HOD" => "bi-building-fill",
        "Faculty" => facultyMode == "Advisor" ? "bi-person-lines-fill" : "bi-person-video3",
        "Student" => "bi-mortarboard-fill",
        _ => "bi-person"
    };

    private string RoleLabel => selectedRole switch
    {
        "Admin" => "Registrar",
        "HOD" => "Head of Department",
        "Faculty" => facultyMode == "Advisor" ? "Faculty Advisor" : "Faculty Teacher",
        "Student" => "Student",
        _ => selectedRole
    };

    private string RoleSub => selectedRole switch
    {
        "Admin" => "Academic records, documents and official notices",
        "HOD" => "Course offerings, faculty allocation and department review",
        "Faculty" => facultyMode == "Advisor" ? "Advising, student progress and counseling" : "Assigned courses, attendance and evaluation",
        "Student" => "Courses, GCR rooms, attendance, services and requests",
        _ => ""
    };

    private string RoleColor => selectedRole switch
    {
        "Admin" => "#dc2626",
        "HOD" => "#2563eb",
        "Faculty" => "#16a34a",
        "Student" => "#0891b2",
        _ => "#0f172a"
    };

    private string RoleBg => selectedRole switch
    {
        "Admin" => "#fef2f2",
        "HOD" => "#eff6ff",
        "Faculty" => "#f0fdf4",
        "Student" => "#ecfeff",
        _ => "#f8fafc"
    };

    private string EmailHint => selectedRole switch
    {
        "Admin" => "admin@au.edu.pk",
        "HOD" => "hod.cs@au.edu.pk",
        "Faculty" => "bilal.raza@au.edu.pk",
        "Student" => "241844@students.au.edu.pk",
        _ => "your.email@au.edu.pk"
    };
}
