@page "/dashboard/lostfound"
@rendermode @(new InteractiveServerRenderMode())
@layout SmartCampus.Components.Layout.MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Student")]
@implements IDisposable
@inject CampusRealtimeService Campus

<PageTitle>Lost & Found — SmartCampus</PageTitle>

<section class="campus-page">
    <div class="module-hero lost-hero"><div><span class="eyebrow"><span class="pulse-dot"></span> Lost & Found Portal</span><h1>Find, Report, Claim</h1><p>Real university flow: report lost/found items, search/filter records, claim items and notify students.</p></div><span class="hero-pill">@Campus.OpenLostFound Open Cases</span></div>
    <div class="metric-grid three"><div class="metric-card"><span class="metric-icon bg-yellow"><i class="bi bi-search"></i></span><div><h3>@Campus.LostFound.Count(x => x.Type == "Lost")</h3><p>Lost Reports</p></div></div><div class="metric-card"><span class="metric-icon bg-green"><i class="bi bi-box-seam"></i></span><div><h3>@Campus.LostFound.Count(x => x.Type == "Found")</h3><p>Found Reports</p></div></div><div class="metric-card"><span class="metric-icon bg-purple"><i class="bi bi-hand-index-thumb"></i></span><div><h3>@Campus.LostFound.Count(x => x.Status == "Claimed")</h3><p>Claimed</p></div></div></div>
    <div class="dashboard-grid">
        <div class="content-card span-4 sticky-card"><div class="section-head"><div><h2>Report Item</h2><p>Create report and push live alert.</p></div></div><input class="form-control smart-input" placeholder="Item title" @bind="title" @bind:event="oninput" /><div class="two-cols"><select class="form-select smart-input" @bind="type"><option>Lost</option><option>Found</option></select><select class="form-select smart-input" @bind="category"><option>Electronics</option><option>Documents</option><option>Books</option><option>Accessories</option><option>Other</option></select></div><input class="form-control smart-input" placeholder="Location" @bind="location" @bind:event="oninput" /><textarea class="form-control smart-input" placeholder="Description" @bind="description" @bind:event="oninput"></textarea><button class="btn primary-action w-100" @onclick="Report"><i class="bi bi-send me-1"></i>Report Item</button></div>
        <div class="content-card span-8"><div class="toolbar-grid"><input class="form-control smart-input" placeholder="Search item, location, reporter..." @bind="search" @bind:event="oninput" /><select class="form-select smart-input" @bind="filterType"><option>All Types</option><option>Lost</option><option>Found</option></select><select class="form-select smart-input" @bind="filterCategory"><option>All Categories</option><option>Electronics</option><option>Documents</option><option>Books</option><option>Accessories</option><option>Other</option></select><select class="form-select smart-input" @bind="filterStatus"><option>All Status</option><option>Open</option><option>Claimed</option></select></div><div class="card-grid mt-3">@foreach (var item in FilteredItems){<div class="info-card"><div class="d-flex justify-content-between"><span class="soft-badge @(item.Type == "Found" ? "success" : "warning")">@item.Type</span><span class="status-badge @item.Status.ToLower()">@item.Status</span></div><h3>@item.Title</h3><p>@item.Description</p><div class="mini-meta"><span><i class="bi bi-geo-alt"></i> @item.Location</span><span><i class="bi bi-person"></i> @item.ReportedBy</span><span><i class="bi bi-clock"></i> @item.ReportedOn.ToString("MMM dd, hh:mm tt")</span></div><div class="action-row"><button class="mini-action" @onclick="() => Campus.ClaimLostFound(item.Id)"><i class="bi bi-hand-index"></i> Claim/Open</button><button class="mini-action danger" @onclick="() => Campus.DeleteLostFound(item.Id)"><i class="bi bi-trash"></i> Delete</button></div></div>}</div>@if (!FilteredItems.Any()) { <div class="empty-state"><i class="bi bi-search-heart"></i><h3>No matching case</h3><p>Change filters or report a new item.</p></div> }</div>
    </div>
</section>

@code {
    private string search = ""; private string filterType = "All Types"; private string filterCategory = "All Categories"; private string filterStatus = "All Status";
    private string title = ""; private string type = "Lost"; private string category = "Electronics"; private string location = "CS Block"; private string description = "";
    private IEnumerable<LostFoundItem> FilteredItems => Campus.LostFound.Where(x => string.IsNullOrWhiteSpace(search) || x.Title.Contains(search, StringComparison.OrdinalIgnoreCase) || x.Location.Contains(search, StringComparison.OrdinalIgnoreCase) || x.ReportedBy.Contains(search, StringComparison.OrdinalIgnoreCase)).Where(x => filterType == "All Types" || x.Type == filterType).Where(x => filterCategory == "All Categories" || x.Category == filterCategory).Where(x => filterStatus == "All Status" || x.Status == filterStatus).OrderByDescending(x => x.ReportedOn);
    private void Report(){ Campus.ReportLostFound(title, category, type, location, description); title = ""; description = ""; }
    protected override void OnInitialized() => Campus.OnChange += Refresh; private void Refresh() => InvokeAsync(StateHasChanged); public void Dispose() => Campus.OnChange -= Refresh;
}
