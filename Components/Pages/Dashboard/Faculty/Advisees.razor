@page "/dashboard/faculty/advisees"
@rendermode @(new InteractiveServerRenderMode())
@layout SmartCampus.Components.Layout.FacultyLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Faculty")]

@inject AuthenticationStateProvider AuthStateProvider
@inject CourseRegistrationRequestService RequestService

<PageTitle>Advisor Requests - SmartCampus</PageTitle>

<div class="sc-profile-page">
    <div class="sc-banner" style="background:linear-gradient(135deg,#14532d,#15803d)">
        <div class="sc-banner-inner">
            <div class="sc-banner-avatar" style="background:#166534">
                <i class="bi bi-person-lines-fill"></i>
            </div>
            <div class="sc-banner-info">
                <h2 class="sc-banner-name">Advisor Requests</h2>
                <p class="sc-banner-meta">@department course registration and additional course requests</p>
            </div>
        </div>
    </div>

    <div style="max-width:1150px;margin:1.5rem auto;padding:0 1.5rem">

        @if (!RequestService.IsRegistrationOpen)
        {
            <div class="alert alert-warning">Course registration is currently closed.</div>
        }

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert sc-alert-success">@message</div>
        }

        <div class="sc-card">
            <div class="sc-card-title">REQUESTS FROM STUDENTS</div>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Course</th>
                            <th>Type</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Advisor Remarks</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in requests)
                        {
                            <tr>
                                <td>
                                    <strong>@req.StudentName</strong><br />
                                    <small class="text-muted">@req.StudentId · @req.Semester</small>
                                </td>
                                <td>
                                    <strong>@req.CourseCode</strong><br />
                                    <small class="text-muted">@req.CourseTitle</small>
                                </td>
                                <td>@req.RequestType</td>
                                <td>@req.StudentReason</td>
                                <td><span class="badge @StatusClass(req.Status)">@req.Status</span></td>
                                <td>
                                    @if (req.Status == "Pending Advisor Review")
                                    {
                                        <input class="form-control sc-input"
                                               placeholder="Write advisor remarks..."
                                               @bind="remarks[req.Id]" />
                                    }
                                    else
                                    {
                                        @req.AdvisorRemarks
                                    }
                                </td>
                                <td class="text-end">
                                    @if (req.Status == "Pending Advisor Review")
                                    {
                                        <button class="btn btn-sm btn-success"
                                                @onclick="() => Forward(req.Id)">
                                            Forward to HOD
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Sent to HOD</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@code {
    private string department = "";
    private string? message;
    private List<CourseRegistrationRequest> requests = new();
    private Dictionary<int, string> remarks = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        department = auth.User.FindFirst("Department")?.Value ?? "Computer Science";
        LoadRequests();
    }

    private void LoadRequests()
    {
        requests = RequestService.GetForAdvisor(department).ToList();

        foreach (var request in requests)
        {
            if (!remarks.ContainsKey(request.Id))
                remarks[request.Id] = request.AdvisorRemarks;
        }
    }

    private void Forward(int id)
    {
        var remark = remarks.TryGetValue(id, out var value) ? value : "";

        if (string.IsNullOrWhiteSpace(remark))
        {
            message = "Please add advisor remarks before forwarding to HOD.";
            return;
        }

        RequestService.ForwardToHod(id, remark);
        message = "Request forwarded to HOD for final approval.";
        LoadRequests();
    }

    private static string StatusClass(string status)
    {
        return status switch
        {
            "Pending Advisor Review" => "bg-warning text-dark",
            "Forwarded to HOD" => "bg-primary",
            "Approved by HOD" => "bg-success",
            "Rejected by HOD" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
