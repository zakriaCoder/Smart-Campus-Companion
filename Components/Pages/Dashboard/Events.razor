@page "/dashboard/events"
@rendermode @(new InteractiveServerRenderMode())
@layout SmartCampus.Components.Layout.MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Student")]
@implements IDisposable
@inject CampusRealtimeService Campus

<PageTitle>Events — SmartCampus</PageTitle>

<section class="campus-page">
    <div class="module-hero event-hero"><div><span class="eyebrow"><span class="pulse-dot"></span> Campus Event Management</span><h1>Events, Societies & Workshops</h1><p>Post events, search, filter, register and see seats update in real time.</p></div><button class="btn btn-light rounded-pill fw-semibold" @onclick="AddFeatured"><i class="bi bi-stars me-1"></i>Post Featured</button></div>
    <div class="featured-event"><div><span class="soft-badge success">Featured Event</span><h2>National AI & Tech Olympiad 2026</h2><p>Compete with CS students across Pakistan. Prize pool Rs. 50,000.</p><div class="d-flex gap-4 flex-wrap"><span><i class="bi bi-calendar"></i> @DateTime.Today.AddDays(7).ToString("MMM dd")</span><span><i class="bi bi-geo-alt"></i> AU Auditorium</span><span><i class="bi bi-people"></i> 247/300 Registered</span></div></div><button class="btn btn-success rounded-pill px-4" @onclick="AddFeatured">Register Demo</button></div>
    <div class="dashboard-grid"><div class="content-card span-4 sticky-card"><div class="section-head"><div><h2>Post Event</h2><p>Create event announcement.</p></div></div><input class="form-control smart-input" placeholder="Event title" @bind="title" @bind:event="oninput" /><div class="two-cols"><select class="form-select smart-input" @bind="category"><option>Workshop</option><option>Competition</option><option>Sports</option><option>Social</option><option>Academic</option></select><input class="form-control smart-input" type="number" @bind="capacity" /></div><input class="form-control smart-input" type="date" @bind="date" /><input class="form-control smart-input" placeholder="Time e.g. 10:00 AM" @bind="time" @bind:event="oninput" /><input class="form-control smart-input" placeholder="Venue" @bind="venue" @bind:event="oninput" /><button class="btn primary-action w-100" @onclick="PostEvent"><i class="bi bi-calendar-plus me-1"></i>Post Event</button></div>
        <div class="content-card span-8"><div class="toolbar-grid three"><input class="form-control smart-input" placeholder="Search events..." @bind="search" @bind:event="oninput" /><select class="form-select smart-input" @bind="filterCategory"><option>All Categories</option><option>Workshop</option><option>Competition</option><option>Sports</option><option>Social</option><option>Academic</option></select><select class="form-select smart-input" @bind="filterStatus"><option>All Status</option><option>Registered</option><option>Open</option><option>Full</option></select></div><div class="card-grid mt-3">@foreach (var ev in FilteredEvents){<div class="event-card"><div class="date-tile"><strong>@ev.Date.ToString("dd")</strong><span>@ev.Date.ToString("MMM")</span></div><span class="soft-badge">@ev.Category</span><h3>@ev.Title</h3><p>@ev.Organizer · @ev.Venue · @ev.Time</p><div class="progress modern-progress"><div class="progress-bar" style="width:@EventPercent(ev)%"></div></div><div class="d-flex justify-content-between small text-muted mt-2"><span>@ev.Registered/@ev.Capacity registered</span><span>@ev.SeatsLeft seats left</span></div><div class="action-row"><button class="mini-action" disabled="@(ev.SeatsLeft == 0 && !ev.IsRegistered)" @onclick="() => Campus.RegisterEvent(ev.Id)"><i class="bi bi-ticket-perforated"></i> @(ev.IsRegistered ? "Cancel" : "Register")</button><button class="mini-action danger" @onclick="() => Campus.DeleteEvent(ev.Id)"><i class="bi bi-trash"></i> Delete</button></div></div>}</div>@if (!FilteredEvents.Any()) { <div class="empty-state"><i class="bi bi-calendar-event"></i><h3>No events found</h3><p>Try another category.</p></div> }</div></div>
</section>

@code {
    private string search = ""; private string filterCategory = "All Categories"; private string filterStatus = "All Status"; private string title = ""; private string category = "Workshop"; private DateTime date = DateTime.Today.AddDays(5); private string time = "10:00 AM"; private string venue = "AU Auditorium"; private int capacity = 100;
    private IEnumerable<CampusEvent> FilteredEvents => Campus.Events.Where(e => string.IsNullOrWhiteSpace(search) || e.Title.Contains(search, StringComparison.OrdinalIgnoreCase) || e.Venue.Contains(search, StringComparison.OrdinalIgnoreCase)).Where(e => filterCategory == "All Categories" || e.Category == filterCategory).Where(e => filterStatus == "All Status" || (filterStatus == "Registered" && e.IsRegistered) || (filterStatus == "Open" && e.SeatsLeft > 0 && !e.IsRegistered) || (filterStatus == "Full" && e.SeatsLeft == 0)).OrderBy(e => e.Date);
    private int EventPercent(CampusEvent ev) => (int)Math.Round(ev.Registered * 100.0 / Math.Max(1, ev.Capacity));
    private void PostEvent(){ Campus.AddEvent(title, category, date, time, venue, capacity); title = ""; }
    private void AddFeatured(){ Campus.AddEvent("Supervisor Demo Day", "Academic", DateTime.Today.AddDays(2), "11:00 AM", "CS Faculty Room", 60); }
    protected override void OnInitialized() => Campus.OnChange += Refresh; private void Refresh() => InvokeAsync(StateHasChanged); public void Dispose() => Campus.OnChange -= Refresh;
}
