@page "/dashboard/marketplace"
@rendermode @(new InteractiveServerRenderMode())
@layout SmartCampus.Components.Layout.MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Student")]
@implements IDisposable
@inject CampusRealtimeService Campus

<PageTitle>Marketplace — SmartCampus</PageTitle>

<section class="campus-page">
    <div class="module-hero market-hero"><div><span class="eyebrow"><span class="pulse-dot"></span> Student Marketplace</span><h1>Buy & Sell Inside Campus</h1><p>List books, gadgets and accessories with filters, sold status and live dashboard updates.</p></div><span class="hero-pill">@Campus.ActiveListings Active Listings</span></div>
    <div class="dashboard-grid"><div class="content-card span-4 sticky-card"><div class="section-head"><div><h2>List Item</h2><p>Create product listing.</p></div></div><input class="form-control smart-input" placeholder="Product title" @bind="title" @bind:event="oninput" /><div class="two-cols"><select class="form-select smart-input" @bind="category"><option>Books</option><option>Electronics</option><option>Accessories</option><option>Clothing</option><option>Lab Equipment</option></select><select class="form-select smart-input" @bind="condition"><option>Like New</option><option>Good</option><option>Used</option></select></div><input class="form-control smart-input" type="number" placeholder="Price" @bind="price" /><textarea class="form-control smart-input" placeholder="Details" @bind="details" @bind:event="oninput"></textarea><button class="btn primary-action w-100" @onclick="ListItem"><i class="bi bi-bag-plus me-1"></i>List Item</button></div>
        <div class="content-card span-8"><div class="toolbar-grid"><input class="form-control smart-input" placeholder="Search books, gadgets, accessories..." @bind="search" @bind:event="oninput" /><select class="form-select smart-input" @bind="filterCategory"><option>All Categories</option><option>Books</option><option>Electronics</option><option>Accessories</option><option>Clothing</option><option>Lab Equipment</option></select><select class="form-select smart-input" @bind="filterCondition"><option>All Conditions</option><option>Like New</option><option>Good</option><option>Used</option></select><select class="form-select smart-input" @bind="filterStatus"><option>All Status</option><option>Available</option><option>Sold</option></select></div><div class="card-grid market-grid mt-3">@foreach (var item in FilteredItems){<div class="product-card @(item.Status == "Sold" ? "sold" : "")"><div class="product-art"><i class="bi @ProductIcon(item.Category)"></i></div><div class="p-3"><div class="d-flex justify-content-between"><span class="soft-badge">@item.Category</span><span class="status-badge @item.Status.ToLower()">@item.Status</span></div><h3>@item.Title</h3><p>@item.Details</p><div class="price">Rs. @item.Price.ToString("0")</div><div class="mini-meta"><span><i class="bi bi-person-circle"></i> @item.Seller</span><span><i class="bi bi-star-fill text-warning"></i> @item.Rating</span></div><div class="action-row"><button class="mini-action" disabled="@(item.Status == "Sold")"><i class="bi bi-chat-dots"></i> Contact</button><button class="mini-action" @onclick="() => Campus.ToggleListingSold(item.Id)"><i class="bi bi-check2-circle"></i> Sold/Available</button><button class="mini-action danger" @onclick="() => Campus.DeleteMarketplaceItem(item.Id)"><i class="bi bi-trash"></i></button></div></div></div>}</div>@if (!FilteredItems.Any()) { <div class="empty-state"><i class="bi bi-shop"></i><h3>No product found</h3><p>Add a listing or change filters.</p></div> }</div></div>
</section>

@code {
    private string search = ""; private string filterCategory = "All Categories"; private string filterCondition = "All Conditions"; private string filterStatus = "All Status"; private string title = ""; private string category = "Books"; private string condition = "Good"; private decimal price = 500; private string details = "";
    private IEnumerable<MarketplaceItem> FilteredItems => Campus.Marketplace.Where(m => string.IsNullOrWhiteSpace(search) || m.Title.Contains(search, StringComparison.OrdinalIgnoreCase) || m.Details.Contains(search, StringComparison.OrdinalIgnoreCase) || m.Seller.Contains(search, StringComparison.OrdinalIgnoreCase)).Where(m => filterCategory == "All Categories" || m.Category == filterCategory).Where(m => filterCondition == "All Conditions" || m.Condition == filterCondition).Where(m => filterStatus == "All Status" || m.Status == filterStatus).OrderByDescending(m => m.PostedOn);
    private string ProductIcon(string cat) => cat switch { "Books" => "bi-book", "Electronics" => "bi-laptop", "Accessories" => "bi-bag", "Clothing" => "bi-person-standing", "Lab Equipment" => "bi-tools", _ => "bi-box" };
    private void ListItem(){ Campus.AddMarketplaceItem(title, category, condition, price, details); title = ""; details = ""; }
    protected override void OnInitialized() => Campus.OnChange += Refresh; private void Refresh() => InvokeAsync(StateHasChanged); public void Dispose() => Campus.OnChange -= Refresh;
}
